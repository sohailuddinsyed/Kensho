# Kensho — local dev environment template
# Copy to .env for local development ONLY
# Never commit real values. All production credentials live in AWS Secrets Manager.

# AWS region
AWS_REGION=ap-south-1

# AWS credentials (local dev only — use IAM roles in Lambda)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Twilio (local dev only — use kensho/twilio in Secrets Manager in prod)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Anthropic (local dev only — use kensho/anthropic in Secrets Manager in prod)
ANTHROPIC_API_KEY=your_anthropic_api_key

# IIFL (local dev only — use kensho/iifl in Secrets Manager in prod)
IIFL_API_KEY=your_iifl_api_key
IIFL_SECRET_KEY=your_iifl_secret_key
IIFL_CLIENT_CODE=your_iifl_client_code

# Kensho config (local dev only — use kensho/config in Secrets Manager in prod)
WHATSAPP_ALLOWLIST=whatsapp:+91XXXXXXXXXX
